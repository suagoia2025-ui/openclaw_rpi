# Copiar a .env en la misma carpeta o exportar en el shell (no commitear .env con secretos).
# Directorio base donde están los pesos (Whisper GGML, GGUF Phi-3, Piper .onnx + .json).
VOICE_MODELS_DIR="${HOME}/voice-models"

# --- whisper.cpp ---
# Binario compilado (ej. build/bin/whisper-cli o main según versión).
export WHISPER_BIN="${WHISPER_BIN:-$HOME/src/whisper.cpp/build/bin/whisper-cli}"
# Modelo tiny multilingüe (recomendado para español): ggml-tiny.bin
export WHISPER_MODEL="${VOICE_MODELS_DIR}/whisper/ggml-tiny.bin"

# --- llama.cpp ---
export LLAMA_CLI="${LLAMA_CLI:-$HOME/src/llama.cpp/build/bin/llama-cli}"
# Ejemplo de archivo (ajustar nombre real tras descarga):
export PHI3_GGUF="${VOICE_MODELS_DIR}/llm/Phi-3-mini-4k-instruct-Q4_K_M.gguf"

# --- Piper ---
export PIPER_BIN="${PIPER_BIN:-$HOME/.local/bin/piper}"
export PIPER_VOICE_ONNX="${VOICE_MODELS_DIR}/piper/es_CO-female-medium.onnx"
export PIPER_VOICE_JSON="${VOICE_MODELS_DIR}/piper/es_CO-female-medium.onnx.json"

# --- Pipeline ---
# Ruta al system prompt (por defecto: prompts/system_child_educational.txt junto al repo)
export VOICE_SYSTEM_PROMPT="${VOICE_SYSTEM_PROMPT:-}"
export VOICE_LLAMA_CTX="${VOICE_LLAMA_CTX:-2048}"
export VOICE_LLAMA_MAX_TOKENS="${VOICE_LLAMA_MAX_TOKENS:-128}"
