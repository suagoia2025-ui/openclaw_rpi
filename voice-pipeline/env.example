# Copiar a .env: cp env.example .env  y editar rutas si difieren en tu máquina.
# En la Raspberry Pi típica: whisper/llama clonados en $HOME (no en src/).

VOICE_MODELS_DIR="${HOME}/voice-models"

# --- whisper.cpp ---
export WHISPER_BIN="${HOME}/whisper.cpp/build/bin/whisper-cli"
export WHISPER_MODEL="${VOICE_MODELS_DIR}/whisper/ggml-tiny.bin"
# Idioma para whisper-cli (-l). Por defecto es; usa "auto" para detección (más lento).
export VOICE_WHISPER_LANGUAGE="es"

# --- llama.cpp + Phi-3 GGUF (nombre del archivo = el que tengas en llm/) ---
# Inferencia batch: llama-completion + --no-conversation en scripts (ver 05-instalacion §7.1).
export LLAMA_COMPLETION="${HOME}/llama.cpp/build/bin/llama-completion"
# Compatibilidad: si no defines LLAMA_COMPLETION, el pipeline usa LLAMA_CLI.
# export LLAMA_CLI="${HOME}/llama.cpp/build/bin/llama-completion"
export PHI3_GGUF="${VOICE_MODELS_DIR}/llm/Phi-3-mini-4k-instruct-Q4_K_M.gguf"

# --- Piper (wrapper en ~/.local/bin) + voz español desde rhasspy/piper-voices ---
# Por defecto: es_MX-ald-medium (es_CO no está en el índice oficial).
export PIPER_BIN="${HOME}/.local/bin/piper"
export PIPER_VOICE_ONNX="${VOICE_MODELS_DIR}/piper/es_MX-ald-medium.onnx"
export PIPER_VOICE_JSON="${VOICE_MODELS_DIR}/piper/es_MX-ald-medium.onnx.json"

# --- Pipeline ---
# VOICE_SYSTEM_PROMPT: ruta absoluta a un .txt con el system prompt. Si está vacío (""), el
# pipeline usa el archivo por defecto del repo: voice-pipeline/prompts/system_general.txt
# (no hace falta rellenar nada para eso).
export VOICE_SYSTEM_PROMPT=""
# 1/true = aplicar scripts/output_filter.py antes de Piper. Por defecto (vacío) = texto directo del LLM.
# export VOICE_OUTPUT_FILTER="1"
export VOICE_LLAMA_CTX="2048"
# No uses -1: en llama.cpp equivale a generar hasta llenar contexto (muy largo).
export VOICE_LLAMA_MAX_TOKENS="128"
# En RPi4 el LLM puede tardar >10 min; por defecto 2400 s (40 min)
export VOICE_LLAMA_TIMEOUT_SEC="2400"
export VOICE_WHISPER_TIMEOUT_SEC="900"
# Hilos para llama-completion (opcional; p.ej. 4 en Pi4)
export VOICE_LLAMA_THREADS="4"

# --- Micrófono + pipeline en vivo (scripts/live_mic_pipeline.sh) ---
# Segundos de grabación por ejecución (Whisper espera WAV 16 kHz mono).
export VOICE_RECORD_SECONDS="8"
# Entrada ALSA del micrófono; vacío = dispositivo por defecto. ReSpeaker HAT típico: plughw:3,0
# export VOICE_ALSA_CAPTURE="plughw:3,0"
# Tras generar el WAV, reproducir (p.ej. HDMI del TV). 1/true = activado.
# export VOICE_PLAY_AFTER="1"
# export VOICE_ALSA_PLAYBACK="plughw:2,0"
# Frecuencia del WAV Piper (revisar en el .json de la voz si el tono no cuadra).
# export VOICE_ALSA_PLAYBACK_RATE="22050"
# Copiar el WAV de la última grabación (para oír si el mic capta bien): p. ej. /tmp/ultima_pregunta.wav
# export VOICE_DEBUG_SAVE_RECORDING="/tmp/ultima_pregunta.wav"
